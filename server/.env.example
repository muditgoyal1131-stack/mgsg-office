# ── Database ──────────────────────────────────────────────────────────────────
# Railway auto-injects DATABASE_URL when you add the PostgreSQL plugin
DATABASE_URL="postgresql://user:password@host:5432/railway"

# ── App ───────────────────────────────────────────────────────────────────────
PORT=5000
JWT_SECRET="change-this-to-a-long-random-string-min-32-chars"
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set this to your Railway frontend service URL after deploying frontend
FRONTEND_URL="https://mgsg-client.up.railway.app"

# ── File Uploads (Railway Volume) ─────────────────────────────────────────────
# Set UPLOAD_DIR to the Volume mount path you configure in Railway dashboard
UPLOAD_DIR=/data/uploads

# ── Email (Brevo is free 300/day — recommended) ───────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-smtp-password
SMTP_FROM="MGSG Office <noreply@yourdomain.com>"

# ── SMS / WhatsApp (Twilio) ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_SMS_FROM=+91xxxxxxxxxx
TWILIO_WHATSAPP_FROM=+14155238886
ENABLE_WHATSAPP=false
